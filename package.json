{
  "name": "brajyatra-complete",
  "version": "2.0.0",
  "description": "BrajYatra.AI — Sacred Braj Travel Planner with Python/FastAPI Backend",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server_py && .\\venv\\Scripts\\python.exe -m uvicorn main:app --reload --port 3000",
    "dev:client": "cd client && npm run dev",
    "start": "cd server_py && .\\venv\\Scripts\\python.exe main.py",
    "build": "cd client && npm run build",
    "test": "cd server_py && .\\venv\\Scripts\\python.exe -m pytest tests/ -v",
    "seed": "cd server_py && .\\venv\\Scripts\\python.exe -m agent.db.seed",
    "install:client": "cd client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
