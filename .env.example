# ═══════════════════════════════════════════════════════════
# BrajYatra.AI — Environment Configuration Template
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# Backend: Unified Python/FastAPI server (server_py/)

# === AI Agent ===
GEMINI_API_KEY=                    # https://aistudio.google.com/apikey
LLM_MODE=gemini
OPENWEATHER_API_KEY=               # https://openweathermap.org/api (free tier)

# === Auth Backend ===
MONGO_URI=                         # MongoDB Atlas connection string
JWT_SECRET=                        # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
RESEND_API_KEY=                    # https://resend.com  (for emails)

# === Google OAuth ===
GOOGLE_CLIENT_ID=                  # https://console.cloud.google.com/apis/credentials

# === Google Maps (server-side, if needed) ===
GOOGLE_MAPS_API_KEY=               # https://console.cloud.google.com/apis/library/maps-backend.googleapis.com

# === Ports ===
AGENT_PORT=3000
CLIENT_PORT=5173
NODE_ENV=development

# === Security ===
JWT_ISSUER=brajyatra.ai
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
