# ═══════════════════════════════════════════════════════════
# BrajYatra.AI — Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════

# === AI Agent (server/agent) ===
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODE=gemini
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# === Auth Backend (server/auth) ===
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
JWT_SECRET=generate_a_random_256bit_secret_here
JWT_ISSUER=brajyatra.ai
RESEND_API_KEY=your_resend_api_key_here

# === Ports ===
AGENT_PORT=3000
AUTH_PORT=5000
CLIENT_PORT=5173
NODE_ENV=development

# === CORS (comma-separated allowed origins for production) ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
