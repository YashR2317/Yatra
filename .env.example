# ═══════════════════════════════════════════════════════════
# BrajYatra.AI — Environment Configuration Example
# ═══════════════════════════════════════════════════════════

# === AI Agent (server/agent) ===
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODE=gemini
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# === Auth Backend (server/auth) ===
MONGO_URI=mongodb+srv://<username>:<db_password>@braj.wjpylao.mongodb.net/
JWT_SECRET=your_jwt_secret_here
RESEND_API_KEY=your_resend_api_key_here

# === Ports ===
AGENT_PORT=3000
AUTH_PORT=5000
NODE_ENV=development

# === Frontend (client/.env) ===
# Vite requires VITE_* vars in the client directory:
# VITE_API_URL=http://localhost:5000/api
# VITE_AGENT_URL=http://localhost:3000
